@model CommentViewModelAdd

<div class="page-header">
	<h1>Add Comment</h1>
	<p class="subtitle">Add a tracking note for shipment #@Model.Shipping.Id.</p>
</div>

<div class="form-card card-surface animate-in">
	<form method="post" asp-action="Add" asp-controller="Commentary">
		<input type="hidden" name="shippingID" value="@Model.Shipping.Id" />
		<div class="mb-3">
			<label for="comment" class="form-label">Comment</label>
			<textarea class="form-control" id="comment" name="Comment" rows="3"
				placeholder="Describe the current status or location..." required></textarea>
		</div>
		<button type="submit" class="btn btn-primary w-100">
			<i class="bi bi-chat-left-dots me-2"></i>Add comment
		</button>
	</form>
</div>

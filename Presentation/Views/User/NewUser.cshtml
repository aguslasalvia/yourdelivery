@using Core.Enums
@model UsersViewModelNewUser

<div class="page-header">
	<h1>Add Employee</h1>
	<p class="subtitle">Register a new team member.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
	<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@Model.Message</div>
}

<div class="form-card form-card--wide card-surface animate-in">
	<div class="profile-avatar">
		<img src="/assets/unknownProfile.png" alt="New user">
		<div class="profile-avatar__meta">
			<h2>New employee</h2>
			<span class="text-muted">Fill in the details below</span>
		</div>
	</div>

	<form asp-action="SubmitNewUser" asp-controller="User" method="post">
		@Html.AntiForgeryToken()
		<input type="hidden" name="Id" value="" />

		<div class="form-grid">
			<div>
				<label class="form-label">Email</label>
				<input class="form-control" name="Email" placeholder="name@yourdelivery.com" />
			</div>
			<div>
				<label class="form-label">Password</label>
				<input class="form-control" type="password" name="Password" placeholder="Password" />
			</div>
			<div>
				<label class="form-label">Name</label>
				<input class="form-control" name="Name" placeholder="Name" />
			</div>
			<div>
				<label class="form-label">Lastname</label>
				<input class="form-control" name="Lastname" placeholder="Lastname" />
			</div>
			<div>
				<label class="form-label">Role</label>
				<select class="form-select" name="Role">
					<option disabled value="@Role.Administrator">Administrator</option>
					<option selected="selected" value="@Role.Employee">Employee</option>
					<option disabled value="@Role.Client">Client</option>
				</select>
			</div>
			<div>
				<label class="form-label">Gender</label>
				<select class="form-select" name="Gender">
					<option selected="selected" disabled value="">Choose a gender</option>
					<option value="@Gender.Female">Female</option>
					<option value="@Gender.Male">Male</option>
				</select>
			</div>
			<div>
				<label class="form-label">Phone</label>
				<input class="form-control" name="Phone" placeholder="Phone" />
			</div>
			<div>
				<label class="form-label">Birth date</label>
				<input type="date" class="form-control" name="Birth" />
			</div>
		</div>

		<div class="form-actions">
			<button type="submit" class="btn btn-success" title="Save">
				<i class="bi bi-check-circle me-2"></i>Save employee
			</button>
		</div>
	</form>
</div>

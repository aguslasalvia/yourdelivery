
<table class="custom-table table w-100 mt-5">
    <thead>
    <tr>
        <th>Full Name</th>
        <th>Phone</th>
        <th>Email</th>
        
        @* This is a header for the button functionality *@
        <th class="p-0"></th>
    </tr>
    </thead>
    <tbody class="" >
    @for(var i = 0; i < 10; i++)
    {
        <tr class="">
            <td>Pepe @i</td>
            <td>Phone @i</td>
            <td>Email @i</td>

            <td><a class="btn btn-secondary" href="~/User/Profile?email=">Details</a></td>
        </tr>
    }
    </tbody>
</table>
@using Core.Enums
@using DTO.Users
@model UsersViewModelProfile

@{
	var isAdmin = Context.Session.GetString("Role") == Role.Administrator.ToString();
}

<div class="page-header">
	<h1>Profile</h1>
	<p class="subtitle">View and update account details.</p>
</div>

<div class="form-card form-card--wide card-surface animate-in">
	<div class="profile-avatar">
		@if (Enum.GetName(Model.User.Gender) == Gender.Female.ToString())
		{
			<img src="/assets/womanProfile.png" alt="User photo">
		}
		else
		{
			<img src="/assets/manProfile.png" alt="User photo">
		}
		<div class="profile-avatar__meta">
			<h2>@Model.User.Name @Model.User.Lastname</h2>
			<span class="text-muted">@Model.User.Email</span>
		</div>
	</div>

	<form asp-action="Update" asp-controller="User" method="post">
		@Html.AntiForgeryToken()
		<input type="hidden" name="Id" value="@Model.User.Id" />

		<div class="form-grid">
			<div>
				<label class="form-label">Email</label>
				<input class="form-control" name="Email" value="@Model.User.Email" />
			</div>
			<div>
				<label class="form-label">Password</label>
				<input class="form-control" type="password" name="Password" value="@Model.User.Password" />
			</div>
			<div>
				<label class="form-label">Name</label>
				<input class="form-control" name="Name" value="@Model.User.Name" />
			</div>
			<div>
				<label class="form-label">Lastname</label>
				<input class="form-control" name="Lastname" value="@Model.User.Lastname" />
			</div>
			<div>
				<label class="form-label">Role</label>
				<select class="form-select" name="Role">
					@if (Model.UserRole == Role.Administrator)
					{
						<option value="@((int)Role.Administrator)" selected="@(Model.User.Role == Role.Administrator)">Administrator</option>
						<option value="@((int)Role.Employee)" selected="@(Model.User.Role == Role.Employee)">Employee</option>
						<option value="@((int)Role.Client)" selected="@(Model.User.Role == Role.Client)">Client</option>
					}
					else if (Model.UserRole == Role.Employee)
					{
						<option value="@((int)Role.Employee)" selected="@(Model.User.Role == Role.Employee)">Employee</option>
					}
					else
					{
						<option value="@((int)Role.Client)" selected="@(Model.User.Role == Role.Client)">Client</option>
					}
				</select>
			</div>
			<div>
				<label class="form-label">Gender</label>
				<select class="form-select" name="Gender">
					<option value="@((int)Gender.Female)" selected="@(Model.User.Gender == Gender.Female)">Female</option>
					<option value="@((int)Gender.Male)" selected="@(Model.User.Gender == Gender.Male)">Male</option>
				</select>
			</div>
			<div>
				<label class="form-label">Phone</label>
				<input class="form-control" name="Phone" value="@Model.User.Phone" />
			</div>
			<div>
				<label class="form-label">Birth date</label>
				<input type="date" class="form-control" name="Birth" value="@Model.User.Birth.ToString("yyyy-MM-dd")" />
			</div>
		</div>

		<div class="form-actions">
			<button type="submit" class="btn btn-success" title="Save changes">
				<i class="bi bi-check-circle me-2"></i>Save changes
			</button>
		</div>
	</form>

	@if (isAdmin)
	{
		<form method="post" asp-action="Delete" asp-controller="User" class="profile-danger">
			@Html.AntiForgeryToken()
			<input type="hidden" name="email" value="@Model.User.Email" />
			<button type="submit" class="btn btn-danger" title="Delete profile">
				<i class="bi bi-trash me-2"></i>Delete account
			</button>
		</form>
	}
</div>

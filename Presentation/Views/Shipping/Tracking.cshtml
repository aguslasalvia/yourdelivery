@using Core.Enums
@model ShippingViewModelTracking

<div class="page-header text-center">
	<h1>Track your package</h1>
	<p class="subtitle">Enter a tracking number to see its current status.</p>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
	<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>@Model.Message</div>
}

<div class="form-card card-surface animate-in">
	<form asp-action="Tracking" asp-controller="Shipping" method="get">
		<div class="input-group">
			<span class="input-group-text"><i class="bi bi-geo-alt-fill"></i></span>
			<input type="number" class="form-control" name="trackingNumber" placeholder="Tracking number"
				aria-label="trackingNumber" required>
			<button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Track</button>
		</div>
	</form>
</div>

@if (Model.Shipping != null)
{
	<div class="tracking-result card-surface animate-in">
		<div class="tracking-result__head">
			<div>
				<span class="tracking-result__label">Tracking number</span>
				<h2 class="tracking-result__id">#@Model.Shipping.Id</h2>
			</div>
			@if (Model.Shipping.State == ShippingState.OnProcess)
			{
				<span class="status-badge status-badge--process">@Model.Shipping.State</span>
			}
			else if (Model.Shipping.State == ShippingState.Finished)
			{
				<span class="status-badge status-badge--finished">@Model.Shipping.State</span>
			}
			else
			{
				<span class="status-badge status-badge--unknown">Unknown</span>
			}
		</div>
		<div class="tracking-result__grid">
			<div>
				<span class="tracking-result__label">Client</span>
				<p>@Model.Shipping.Client.Email</p>
			</div>
			<div>
				<span class="tracking-result__label">Employee</span>
				<p>@Model.Shipping.Employee.Email</p>
			</div>
		</div>
	</div>
}
else
{
	<figure class="tracking-illustration">
		<img src="/assets/tracking.png" alt="Tracking illustration" />
	</figure>
}

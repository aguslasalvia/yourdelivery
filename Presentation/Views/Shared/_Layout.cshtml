<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - YourDelivery</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true" />
</head>

<body>
@if (@Context.Session.GetString("User") != null)
{
	Html.RenderPartialAsync("_Sidebar");
}
<div class="container h-100 w-100">
	<main role="main" class="">
		@RenderBody()
	</main>
</div>

@if (Context.Session.GetString("User") == null)
	{
		<footer class="footer text-muted text-center ">
			<div class="container bg-secondary">
				&copy; 2025 - Obligatorio - N3F - Agustin Lasalvia - Martin Leib
			</div>
		</footer>
	} 

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>

</html>

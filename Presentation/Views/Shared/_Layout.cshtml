<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>@ViewData["Title"] - YourDelivery</title>
	<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
	<link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
	<link rel="stylesheet" href="~/Presentation.styles.css" asp-append-version="true" />
</head>

@{
	var isLoggedIn = Context.Session.GetString("User") != null;
}

<body class="app-body @(isLoggedIn ? "" : "auth-body")">
	@if (isLoggedIn)
	{
		@await Html.PartialAsync("_Sidebar")
		<main role="main" class="app-main animate-in">
			@RenderBody()
		</main>
	}
	else
	{
		<main role="main" class="auth-main">
			@RenderBody()
		</main>
		<footer class="auth-footer text-center">
			&copy; 2025 - YourDelivery - Agustin Lasalvia
		</footer>
	}

	<script src="~/lib/jquery/dist/jquery.min.js"></script>
	<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
	<script src="~/js/site.js" asp-append-version="true"></script>
	@await RenderSectionAsync("Scripts", required: false)
</body>

</html>

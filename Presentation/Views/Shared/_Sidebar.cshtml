@using System.Text.Json
@using Core.Enums
@using DTO.Users

@{
	var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
	var userJson = Context.Session.GetString("User");
	var currentUser = string.IsNullOrEmpty(userJson) ? null : JsonSerializer.Deserialize<UserProfileDto>(userJson);
	var userName = currentUser?.Name ?? "User";
	var userEmail = currentUser?.Email ?? "";
	var userRole = Context.Session.GetString("Role") ?? "";
	string IsActive(string action) => currentAction == action ? "active" : "";
}

<aside id="sidebar" class="sidebar">
	<div class="sidebar__brand">
		<a href="@Url.Action("Dashboard", "User")" class="sidebar__logo" title="YourDelivery">
			<i class="bi bi-box-seam-fill"></i>
			<span class="sidebar__label">YourDelivery</span>
		</a>
		<button type="button" class="sidebar__toggle" id="sidebarToggle" aria-label="Toggle sidebar">
			<i class="bi bi-chevron-left"></i>
		</button>
	</div>

	<nav class="sidebar__nav">
		<a href="@Url.Action("Dashboard", "User")" class="sidebar__link @IsActive("Dashboard")" title="Dashboard">
			<i class="bi bi-speedometer2"></i>
			<span class="sidebar__label">Dashboard</span>
		</a>

		@if (userRole == Role.Administrator.ToString())
		{
			<span class="sidebar__section">Admin</span>
			<a href="@Url.Action("Users", "User")" class="sidebar__link @IsActive("Users")" title="Users">
				<i class="bi bi-people"></i>
				<span class="sidebar__label">Users</span>
			</a>
			<a href="@Url.Action("NewUser", "User")" class="sidebar__link @IsActive("NewUser")" title="Add Employee">
				<i class="bi bi-person-plus"></i>
				<span class="sidebar__label">Add Employee</span>
			</a>
		}

		<span class="sidebar__section">Shipping</span>
		<a href="@Url.Action("NewShipping", "Shipping")" class="sidebar__link @IsActive("NewShipping")" title="New Shipment">
			<i class="bi bi-plus-square"></i>
			<span class="sidebar__label">New Shipment</span>
		</a>
		<a href="@Url.Action("List", "Shipping")" class="sidebar__link @IsActive("List")" title="All Shipments">
			<i class="bi bi-table"></i>
			<span class="sidebar__label">All Shipments</span>
		</a>
		<a href="@Url.Action("Tracking", "Shipping")" class="sidebar__link @IsActive("Tracking")" title="Track Package">
			<i class="bi bi-geo-alt"></i>
			<span class="sidebar__label">Track Package</span>
		</a>

		<span class="sidebar__section">Account</span>
		<a href="@Url.Action("Profile", "User", new { email = userEmail })" class="sidebar__link @IsActive("Profile")" title="Profile">
			<i class="bi bi-person-circle"></i>
			<span class="sidebar__label">Profile</span>
		</a>
	</nav>

	<div class="sidebar__footer">
		<div class="sidebar__user" title="@userName">
			<span class="sidebar__avatar">@(string.IsNullOrEmpty(userName) ? "U" : userName.Substring(0, 1).ToUpper())</span>
			<span class="sidebar__label sidebar__user-meta">
				<span class="sidebar__user-name">@userName</span>
				<span class="sidebar__user-role">@userRole</span>
			</span>
		</div>
		<a href="@Url.Action("Logout", "Auth")" class="sidebar__link sidebar__logout" title="Sign Out">
			<i class="bi bi-box-arrow-right"></i>
			<span class="sidebar__label">Sign Out</span>
		</a>
	</div>
</aside>
